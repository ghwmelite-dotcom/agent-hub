# Copy this file to `.env` and fill in your values.
# Never commit `.env` to git.

# ──────────────────────────────────────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram (see README).
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID. The bot will refuse to talk to anyone else.
# Get it by messaging @userinfobot on Telegram, or run the bot once and check
# logs — it logs every incoming user ID.
TELEGRAM_ALLOWED_USER_ID=

# ──────────────────────────────────────────────────────────────────────────────
# Anthropic / Claude — auth
# ──────────────────────────────────────────────────────────────────────────────
# How the bot authenticates to Claude. THREE modes:
#
#   subscription (default, recommended for Claude Code subscribers)
#     Uses your existing Claude Code OAuth (`claude auth login`). The
#     bot ACTIVELY SCRUBS ANTHROPIC_API_KEY from its environment at
#     startup so it can't accidentally fall back to per-token billing.
#
#   api_key
#     Forces per-token API billing. Requires ANTHROPIC_API_KEY below.
#     The bot exits at startup if the key is missing.
#
#   auto
#     Use API key if present, else subscription. Handy for mixed setups
#     where you may or may not have a key.
ANTHROPIC_AUTH_MODE=subscription

# Only needed when ANTHROPIC_AUTH_MODE is `api_key` or `auto`. In
# `subscription` mode (the default) this value is scrubbed from env
# before the SDK starts. Get a key at https://console.anthropic.com if
# you actually want per-token billing.
ANTHROPIC_API_KEY=

# Default model for agents. Override per-role in agent_hub/agents/roles/*.yaml.
AGENT_DEFAULT_MODEL=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────────────────────────
# Workspaces — where agents are allowed to read/write files
# ──────────────────────────────────────────────────────────────────────────────
# Comma-separated absolute paths the agents can touch. The first one is the
# default working directory.
AGENT_WORKSPACES=C:\dev\baobab

# Sandbox mode:
#   allowlist — /workspace only accepts paths within AGENT_WORKSPACES (safest)
#   open      — /workspace accepts any folder on the device (most flexible)
AGENT_WORKSPACE_MODE=open

# ──────────────────────────────────────────────────────────────────────────────
# Autonomy
# ──────────────────────────────────────────────────────────────────────────────
# How much the PM can do without asking you first.
#   low    — confirm every step
#   medium — propose a plan, wait for OK, then execute
#   high   — just keep you informed; only ask on destructive / big decisions
PM_AUTONOMY=medium

# ──────────────────────────────────────────────────────────────────────────────
# Storage
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/agent_hub.db
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Dashboard (live activity monitor at http://localhost:<port>)
# Set to 0 to disable.
# ──────────────────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8765
